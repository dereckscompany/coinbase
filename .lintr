linters: linters_with_defaults(
    line_length_linter = line_length_linter(120),
    indentation_linter = indentation_linter(2),
    return_linter = return_linter(return_style = "explicit"),
    # The `regexes` arm admits the `empty_<Shape>()` typed-empty helpers, whose
    # CamelCase suffix is the return-shape name (R/types_coinbase.R) they mirror.
    object_name_linter = object_name_linter(
      styles = c("snake_case", "SNAKE_CASE", "CamelCase"),
      regexes = c("^empty_[A-Z][A-Za-z]*$")
    ),
    # Disabled: long fixture / API-field names are intentional.
    object_length_linter = NULL,
    # Disabled: every flag is a misclassification (file-header banners,
    # documented usage examples, inline test annotations, bug refs).
    commented_code_linter = NULL
  )
exclusions: list(
    "renv/activate.R",
    "packages/*/renv/",
    "scripts/",
    "R/contracts-generated.R"
  )
